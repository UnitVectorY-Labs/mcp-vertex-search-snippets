name: mcp-vertex-search-snippets
default_branch: main
config:
  description: "A lightweight MCP server that integrates with Vertex AI Search to retrieve configurable snippets and extractive segments for document discovery."
  license: MIT
  language: go
  release: release-go
  justfile: true
  status: active
  release_github: true
  codecov:
    enabled: true
  docs:
    enabled: false
